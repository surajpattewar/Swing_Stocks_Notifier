# Copy this file to .env and fill in your real values. Never commit .env to git.

# ---- Telegram (recommended, free & easiest) ----
# 1. Message @BotFather on Telegram -> /newbot -> copy the token below
TELEGRAM_BOT_TOKEN=
# 2. Message your new bot once, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    and copy the "chat":{"id": ...} value below
TELEGRAM_CHAT_ID=

# ---- WhatsApp via Twilio (optional, needs a Twilio account) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+91xxxxxxxxxx

# ---- Screener settings ----
MIN_SCORE=3
MAX_STOCKS_TO_SCAN=500
TOP_N_ALERTS=20

SEND_TELEGRAM=False
SEND_WHATSAPP=True

